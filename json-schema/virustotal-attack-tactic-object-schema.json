{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/virustotal/refs/heads/main/json-schema/AttackTacticObject-schema.json",
  "title": "AttackTacticObject",
  "description": "A MITRE ATT&CK tactic (e.g. TA0001 Initial Access).",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Object identifier."
    },
    "type": {
      "type": "string",
      "description": "Object type discriminator."
    },
    "links": {
      "type": "object",
      "description": "Hypermedia links.",
      "properties": {
        "self": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "attributes": {
      "type": "object",
      "description": "Type-specific attributes for AttackTacticObject.",
      "properties": {
        "name": {
          "type": "string",
          "example": "Initial Access"
        },
        "stix_id": {
          "type": "string",
          "example": "x-mitre-tactic--xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
        },
        "description": {
          "type": "string"
        },
        "link": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "relationships": {
      "type": "object",
      "description": "Pre-expanded relationships, keyed by relationship name.",
      "additionalProperties": true
    }
  },
  "required": [
    "id",
    "type",
    "attributes"
  ]
}
{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/virustotal/refs/heads/main/json-structure/virustotal-popular-threat-category-object-structure.json",
  "name": "PopularThreatCategoryObject",
  "description": "A widely-used threat category (e.g. trojan, ransomware, downloader).",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Object identifier."
    },
    "type": {
      "type": "string",
      "description": "Object type discriminator."
    },
    "links": {
      "type": "object",
      "description": "Hypermedia links.",
      "properties": {
        "self": {
          "type": "uri"
        }
      }
    },
    "attributes": {
      "type": "object",
      "description": "Type-specific attributes for PopularThreatCategoryObject.",
      "properties": {
        "category": {
          "type": "string",
          "example": "trojan"
        },
        "count": {
          "type": "int32",
          "description": "Number of distinct files associated with this category."
        }
      }
    },
    "relationships": {
      "type": "object",
      "description": "Pre-expanded relationships, keyed by relationship name.",
      "additionalProperties": true
    }
  },
  "required": [
    "id",
    "type",
    "attributes"
  ]
}